# Usamos Ubuntu como base por ser común en PCs de escritorio
FROM ubuntu:22.04

# Evitar diálogos interactivos durante la instalación
ENV DEBIAN_FRONTEND=noninteractive

# Instalar sudo, dependencias básicas y utilidades de sistema
RUN apt-get update && apt-get install -y \
    sudo \
    bash \
    coreutils \
    util-linux \
    && rm -rf /var/lib/apt/lists/*

# Crear el usuario 'tester' y darle permisos de sudo
RUN useradd -m -s /bin/bash tester && \
    echo "tester ALL=(ALL) NOPASSWD:ALL" >> /etc/sudoers

# Establecer el directorio de trabajo
WORKDIR /home/tester/eaSway

# Cambiar al usuario tester
USER tester