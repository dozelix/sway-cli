# =================================================================
# eaSway - Dockerfile de Testeo
# Emula una instalación limpia de Debian para probar el instalador.
# Versión: 2.0 - 06-05-2026
# Corrección: usuario 'dozelix' (consistente con post_install.sh)
# =================================================================
FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y \
    sudo \
    bash \
    coreutils \
    util-linux \
    && rm -rf /var/lib/apt/lists/*

# BUGFIX: El usuario se llama 'dozelix', igual que en post_install.sh
# Antes era 'tester', lo que causaba que usermod fallara silenciosamente.
RUN useradd -m -s /bin/bash dozelix && \
    echo "dozelix ALL=(ALL) NOPASSWD:ALL" >> /etc/sudoers

WORKDIR /home/dozelix/eaSway

USER dozelix